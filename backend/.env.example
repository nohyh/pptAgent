# OpenAI/LLM Configuration
API_KEY=your-openai-api-key
BASE_URL=your-openai-compatible-base-url
MODEL_PRO=gemini-pro
MODEL_DEEPSEEK=deepseek3.2
MODEL_PHOTO=Nano Banana 2
MODEL_FLASH=gemini-flash

# Secondary LLM Configuration (e.g. DeepSeek)
API_KEY_2=your-deepseek-api-key
BASE_URL_2=https://api.deepseek.com
MODEL_FLASH_2=deepseek-v4-flash

DEBUG_RAW_AI_RESPONSE=true
CORS_ORIGINS=http://localhost:5173
PEXELS_KEY=your-pexels-api-key

# Database Configuration (for V2 Persistence)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ppt_agent
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ppt_agent
