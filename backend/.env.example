# Backend API
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Primary OpenAI-compatible LLM provider
API_KEY=your-primary-llm-api-key
BASE_URL=https://your-openai-compatible-base-url/v1
MODEL_PRO=your-strong-text-model
MODEL_FLASH=your-fast-text-model
MODEL_PHOTO=your-image-model

# Optional secondary LLM provider
API_KEY_2=
BASE_URL_2=
MODEL_FLASH_2=
MODEL_DEEPSEEK=

# Development diagnostics
# true 会在后端控制台打印原始 AI 返回，生产环境应设为 false。
DEBUG_RAW_AI_RESPONSE=false

# Image providers
PEXELS_KEY=your-pexels-api-key

# Database
# Supabase direct connection 示例：
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ppt_agent
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ppt_agent

# Supabase Auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
